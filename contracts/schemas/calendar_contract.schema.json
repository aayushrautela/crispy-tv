{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "calendar_contract fixture",
  "type": "object",
  "required": ["contract_version", "suite", "case_id", "input", "expected"],
  "properties": {
    "contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "suite": {
      "const": "calendar_contract"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "required": ["route", "payload"],
      "properties": {
        "route": {
          "type": "string",
          "enum": ["calendar", "this-week"]
        },
        "payload": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": ["valid", "normalized"],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "normalized": {
          "type": ["object", "null"],
          "required": ["profile_id", "source", "generated_at", "items"],
          "properties": {
            "profile_id": { "type": "string" },
            "source": { "type": "string" },
            "generated_at": { "type": "string" },
            "kind": { "type": ["string", "null"] },
            "items": { "type": "array", "items": { "type": "object" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

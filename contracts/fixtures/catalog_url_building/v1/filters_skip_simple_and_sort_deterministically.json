{
  "contract_version": 1,
  "suite": "catalog_url_building",
  "case_id": "filters_skip_simple_and_sort_deterministically",
  "input": {
    "base_url": "https://catalog.example/addon",
    "encoded_query": null,
    "media_type": "series",
    "catalog_id": "search",
    "skip": 40,
    "limit": 30,
    "filters": [
      {
        "key": "search",
        "value": " dune "
      },
      {
        "key": "genre",
        "value": "Sci Fi"
      },
      {
        "key": "genre",
        "value": "Action"
      }
    ]
  },
  "expected": {
    "urls": [
      "https://catalog.example/addon/catalog/series/search/skip=40/limit=30/genre=Action/genre=Sci%20Fi/search=dune.json",
      "https://catalog.example/addon/catalog/series/search.json?skip=40&limit=30&genre=Action&genre=Sci%20Fi&search=dune"
    ]
  }
}
